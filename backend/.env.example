PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/veritas

# OpenAI — text (/api/analyze), vision Check AI (/api/check-ai), Amazon review endpoints.
# Put secrets only in backend/.env (or project root .env); backend/.env wins if both exist. Never commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

JWT_SECRET=dev-secret-change-me
CHAIN_ENABLED=false
RPC_URL=http://127.0.0.1:8545
VERITAS_CONTRACT_ADDRESS=
SIGNER_PRIVATE_KEY=

# ==============================
# News APIs (backend only)
# Used by POST /api/fact-check (parallel search across providers). Optional — leave blank if unused.
# Register keys with each provider. Primary + _2 fallback supported in code.
# ==============================

NEWSAPI_KEY=
NEWSAPI_KEY_2=

WORLDNEWS_API_KEY=
WORLDNEWS_API_KEY_2=

GNEWS_API_KEY=
GNEWS_API_KEY_2=

THENEWS_API_TOKEN=
THENEWS_API_TOKEN_2=
