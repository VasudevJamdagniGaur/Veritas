PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/veritas

# Required for real text analysis via POST /api/analyze (never commit real keys).
# You can put secrets in EITHER this file (backend/.env) OR the project root .env — backend/.env wins if both set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Vision / Check AI (image → Real vs AI-generated). Must be a vision-capable model.
OPENAI_VISION_MODEL=gpt-4o-mini

JWT_SECRET=dev-secret-change-me
CHAIN_ENABLED=false
RPC_URL=http://127.0.0.1:8545
VERITAS_CONTRACT_ADDRESS=
SIGNER_PRIVATE_KEY=
