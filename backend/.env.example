PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/veritas

# Vertex AI (reel visuals) — use a service account JSON + Application Default Credentials:
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
# (or VERTEX_SERVICE_ACCOUNT_KEY=... — same file; use forward slashes on Windows)
# VERTEX_PROJECT is optional: project id is read from the JSON `project_id` field if omitted.
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-flash
# Optional: Google AI Studio key (tried before Vertex if set)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=dev-secret-change-me
CHAIN_ENABLED=false
RPC_URL=http://127.0.0.1:8545
VERITAS_CONTRACT_ADDRESS=
SIGNER_PRIVATE_KEY=

