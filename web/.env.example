# Veritas web (Vite) — copy to `.env` locally. Do not commit real secrets.
#
# Backend API base (must match your Veritas backend, default port 5000).
# Same origin story as backend `PORT=5000` → `http://localhost:5000/api`
VITE_API_URL=http://localhost:5000/api

# Server-only secrets belong in `backend/.env` only (OpenAI, MongoDB, JWT, news APIs, etc.).
# Do not put those keys here — they would be exposed to the browser in the client bundle.
