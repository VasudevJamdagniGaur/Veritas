PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/veritas

# Required for real reel / text analysis (never commit real keys; copy to .env locally)
OPENAI_API_KEY=
# Optional alias — same secret; Node backend reads either one
REACT_APP_OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

JWT_SECRET=dev-secret-change-me
CHAIN_ENABLED=false
RPC_URL=http://127.0.0.1:8545
VERITAS_CONTRACT_ADDRESS=
SIGNER_PRIVATE_KEY=
